# Application
APP_ENV=development
APP_PORT=8000
PUBLIC_BASE_URL=https://your-tunnel-url.ngrok-free.app

# PostgreSQL
POSTGRES_DB=foodlens
POSTGRES_USER=foodlens
POSTGRES_PASSWORD=foodlens_password
POSTGRES_PORT=5432

# Backend database connection
DB_HOST=postgres
DB_PORT=5432
DB_USER=foodlens
DB_PASSWORD=foodlens_password
DB_NAME=foodlens
DB_SSLMODE=disable

# ML service
ML_SERVICE_URL=http://ml-service:9000
ML_SERVICE_PORT=9000
MODEL_PATH=/app/weights/best.pt
